<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <RelativeLayout
            android:id="@+id/relativeLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <include
                layout="@layout/menu_button_layout" />

        </RelativeLayout>

        <!-- Layout para contener todo el contenido centrado -->
        <LinearLayout
            android:id="@+id/centralLayout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:padding="16dp">

            <!-- Texto para registrar una cuenta nueva, ubicado en la parte inferior -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Seleccione el motivo de su cancelación"
                android:textColor="?attr/colorPrimary"
                android:textStyle="bold"
                android:layout_marginBottom="18dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.5" />

            <!-- Viñetas con checkbox -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="16dp">

                <!-- Problemas con el conductor -->
                <LinearLayout
                    android:id="@+id/optionProblemasConductor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp"
                    android:gravity="center_vertical">

                    <CheckBox
                        android:id="@+id/checkProblemasConductor"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:focusable="false"
                        android:textColor="@color/primaryColor"
                        android:focusableInTouchMode="false" />

                    <TextView
                        android:id="@+id/tvProblemasConductor"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Problemas con el conductor"
                        android:textSize="16sp"
                        android:textColor="@color/textColor"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>

                <!-- Demora excesiva -->
                <LinearLayout
                    android:id="@+id/optionDemoraExcesiva"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp"
                    android:gravity="center_vertical">

                    <CheckBox
                        android:id="@+id/checkDemoraExcesiva"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:focusable="false"
                        android:focusableInTouchMode="false"/>

                    <TextView
                        android:id="@+id/tvDemoraExcesiva"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Demora excesiva"
                        android:textSize="16sp"
                        android:textColor="@color/textColor"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>

                <!-- Cambios en el destino -->
                <LinearLayout
                    android:id="@+id/optionCambiosDestino"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp"
                    android:gravity="center_vertical">

                    <CheckBox
                        android:id="@+id/checkCambiosDestino"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:focusable="false"
                        android:focusableInTouchMode="false"/>

                    <TextView
                        android:id="@+id/tvCambiosDestino"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cambios en el destino"
                        android:textSize="16sp"
                        android:textColor="@color/textColor"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>

                <!-- Otros motivos -->
                <LinearLayout
                    android:id="@+id/optionOtrosMotivos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp"
                    android:gravity="center_vertical">

                    <CheckBox
                        android:id="@+id/checkOtrosMotivos"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:focusable="false"
                        android:focusableInTouchMode="false"/>

                    <TextView
                        android:id="@+id/tvOtrosMotivos"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Otros motivos"
                        android:textSize="16sp"
                        android:textColor="@color/textColor"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>

            </LinearLayout>


            <!-- Layout para contener los campos del formulario -->
            <LinearLayout
                android:id="@+id/formLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:layout_marginTop="24dp">

                <!-- EditText para cambiar nombre con estilo flotante usando TextInputLayout -->
                <LinearLayout
                    style="@style/GeneralLinearLayoutStyle"
                    android:id="@+id/layoutEditPhone"
                    android:layout_marginBottom="16dp">
                    <EditText
                        style="@style/GeneralEditTextStyle"
                        android:id="@+id/edit_phone"
                        android:hint="Escríbanos un comentario adicional"
                        android:inputType="text" />
                </LinearLayout>
            </LinearLayout>

            <!-- Botón para "Guardar cambios" -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/edit_button"
                style="@style/Button.Form"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/button_gradient"
                android:text="Enviar" />

            <TextView
                android:id="@+id/errorText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:textColor="@color/alertColor"
                android:visibility="gone"
                android:textSize="14sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/delete_button" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Sidebar con opciones (Navigation Drawer) -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:fitsSystemWindows="true"
        android:background="#FFF"
        app:headerLayout="@layout/nav_header"
        app:menu="@menu/navigation_menu" />

</androidx.drawerlayout.widget.DrawerLayout>
