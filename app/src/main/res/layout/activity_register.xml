<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <ImageButton
        android:id="@+id/btnBackToMain"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_logout"
        android:contentDescription="Volver al inicio"
        android:background="?attr/selectableItemBackgroundBorderless"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp" />

    <!-- Layout para contener los campos del formulario -->
    <LinearLayout
        android:id="@+id/formLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/btnCreateAccount"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.5">

        <!-- Campo DNI con estilo flotante usando TextInputLayout -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Base.TextInputLayoutStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="DNI"> <!-- Definir el hint aquí -->

            <com.google.android.material.textfield.TextInputEditText
                style="@style/Base.TextInputEditTextStyle"
                android:id="@+id/editTextDNI"
                android:inputType="number" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Campo Nombre con el mismo estilo del DNI -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Base.TextInputLayoutStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nombres"> <!-- Definir el hint aquí -->

            <com.google.android.material.textfield.TextInputEditText
                style="@style/Base.TextInputEditTextStyle"
                android:id="@+id/editTextNombre"
                android:inputType="textPersonName" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Campo Celular con el mismo estilo del DNI -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Base.TextInputLayoutStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Celular"> <!-- Definir el hint aquí -->

            <com.google.android.material.textfield.TextInputEditText
                style="@style/Base.TextInputEditTextStyle"
                android:id="@+id/editTextCelular"
                android:inputType="phone" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Campo Correo con el mismo estilo del DNI -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Base.TextInputLayoutStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Correo"> <!-- Definir el hint aquí -->

            <com.google.android.material.textfield.TextInputEditText
                style="@style/Base.TextInputEditTextStyle"
                android:id="@+id/editTextCorreo"
                android:inputType="textEmailAddress" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Campo Contraseña con el mismo estilo del DNI -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Base.TextInputLayoutStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="contraseña"> <!-- Definir el hint aquí -->

            <com.google.android.material.textfield.TextInputEditText
                style="@style/Base.TextInputEditTextStyle"
                android:id="@+id/editTextContraseña"
                android:inputType="textPassword" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- CheckBox para aceptar términos -->
        <CheckBox
            android:id="@+id/checkBoxTerms"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Al crear su cuenta, usted declara haber aceptado los términos y condiciones"
            android:layout_marginBottom="20dp" />
    </LinearLayout>

    <!-- Botón para crear cuenta -->
    <Button
        android:id="@+id/btnCreateAccount"
        style="@style/Button.Primary"
        android:text="Crear cuenta"
        app:layout_constraintBottom_toTopOf="@+id/textViewLogin"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"/>

    <!-- Texto para iniciar sesión -->

    <TextView
        android:id="@+id/textViewLogin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="¿Ya tienes una cuenta? Iniciar Sesión"
        android:textColor="?attr/colorPrimary"
        android:textStyle="bold"
        android:layout_marginBottom="20dp"
        android:layout_gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5" />

</androidx.constraintlayout.widget.ConstraintLayout>
